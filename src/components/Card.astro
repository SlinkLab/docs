---
import { Badge } from '@astrojs/starlight/components';

interface Props {
	title: string;
	badge?: string;
}

const { title, badge } = Astro.props;
---

<article class="flex flex-col gap-2 p-5 rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 transition-colors duration-150 hover:border-gray-300 dark:hover:border-gray-700">
	<div class="flex items-start justify-between gap-3">
		<h3 class="text-base! font-semibold! text-gray-900 dark:text-white leading-snug m-0! flex-1" set:html={title} />
		{badge && (
			<Badge text={badge} variant="success" size="small" class="flex-shrink-0 mt-0.5" />
		)}
	</div>
	<div class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
		<slot />
	</div>
</article>
